# ── Database ──────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/market_surveillance
TEST_DATABASE_URL=postgresql://postgres:password@localhost:5432/market_surveillance_test

# ── JWT ───────────────────────────────────────────────────────────────
SECRET_KEY=your-256-bit-secret-key-here-generate-with-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── App ───────────────────────────────────────────────────────────────
APP_ENV=development
DEBUG=true

# ── ML Models ─────────────────────────────────────────────────────────
MODEL_DIR=trained_models

# ── Redis (Phase 8: Streaming Ingestion) ──────────────────────────────
# Local dev: redis://localhost:6379/0
# Docker:    redis://redis:6379/0
REDIS_URL=redis://localhost:6379/0

# ── Crypto Data: Binance (Primary) & Bybit (Secondary fallback) ────────
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here
# Bybit: no key needed for public streams (market data only)

# ── US Equities: Alpaca (Primary) & Finnhub (Secondary fallback) ───────
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_API_SECRET=your_alpaca_api_secret_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets
FINNHUB_API_KEY=your_finnhub_api_key_here

# ── Indian Markets: Upstox (Primary) ──────────────────────────────────
UPSTOX_API_KEY=your_upstox_api_key_here
UPSTOX_API_SECRET=your_upstox_api_secret_here
UPSTOX_REDIRECT_URI=http://localhost:8000/auth/upstox/callback
UPSTOX_ACCESS_TOKEN=   # Filled in after OAuth login

# ── Sentiment Data ────────────────────────────────────────────────────
# Finnhub also provides news (uses same key above)
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=MarketSurveillance/1.0

# ── Gemini AI (Phase 9: Auto-MAR Report Generation) ───────────────────
GEMINI_API_KEY=your_google_gemini_api_key_here
